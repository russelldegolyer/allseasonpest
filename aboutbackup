<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
  />
  <title>About | All Season Pest Control</title>
  <meta
    name="description"
    content="Meet the people behind All Season Pest Control."
  />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --text:#ffffff;
      --muted:rgba(255,255,255,.80);
      --muted-soft:rgba(255,255,255,.54);
      --shadow:0 18px 60px rgba(0,0,0,.58);
      --purple:#8b5cf6;
      --active:#8b5cf6;
      --max:1200px;
      --glow:0 0 22px rgba(255,255,255,.12);
      --grid-rgb:139,92,246;
    }

    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
      min-width:0;
    }

    html{
      scroll-behavior:smooth;
      background:#000;
    }

    body{
      background:
        radial-gradient(circle at top, rgba(var(--grid-rgb), .05), transparent 28%),
        linear-gradient(180deg, #000000 0%, #000000 100%);
      background-color:#000;
      color:var(--text);
      font-family:"Sora", Inter, Arial, Helvetica, sans-serif;
      min-height:100vh;
      overflow-x:hidden;
      padding-bottom:max(24px, env(safe-area-inset-bottom));
    }

    a{
      color:inherit;
      text-decoration:none;
    }

    button,
    a{
      -webkit-tap-highlight-color: transparent;
      font: inherit;
    }

    .topbar{
      position:fixed;
      top:0;
      left:0;
      width:100%;
      z-index:1000;
      backdrop-filter:blur(14px);
      background:rgba(0, 0, 0, 0.86);
      border-bottom:1px solid rgba(255,255,255,.24);
    }

    .topbar-inner{
      max-width:var(--max);
      margin:0 auto;
      padding:14px 20px;
      display:flex;
      justify-content:center;
      align-items:center;
    }

    .nav{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      justify-content:center;
    }

    .nav a{
      padding:11px 18px;
      border:1px solid rgba(255,255,255,.34);
      border-radius:999px;
      background:rgba(255,255,255,.01);
      color:#fff;
      font-family:"Oswald", Arial, sans-serif;
      font-weight:600;
      font-size:0.98rem;
      letter-spacing:0.04em;
      text-transform:uppercase;
      transition:0.2s ease;
    }

    .nav a:hover,
    .nav a.active{
      border-color:rgba(255,255,255,.84);
      box-shadow:var(--glow);
      transform:translateY(-1px);
    }

    .page-wrap{
      max-width:1240px;
      margin:0 auto;
      padding:104px 20px 64px;
      overflow-x:hidden;
    }

    .showcase{
      position:relative;
      width:100%;
      border-radius:28px;
      border:1px solid rgba(255,255,255,.08);
      background:
        linear-gradient(180deg, rgba(255,255,255,.004), rgba(255,255,255,.001)),
        rgba(0,0,0,.995);
      box-shadow:var(--shadow);
      overflow:hidden;
      isolation:isolate;
    }

    .showcase::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 18% 14%, rgba(var(--grid-rgb), .045), transparent 22%),
        radial-gradient(circle at 82% 20%, rgba(var(--grid-rgb), .025), transparent 24%),
        radial-gradient(circle at 50% 100%, rgba(var(--grid-rgb), .04), transparent 34%);
      pointer-events:none;
      z-index:1;
    }

    .section-stack{
      position:relative;
      z-index:3;
      padding:22px 22px 18px;
      display:flex;
      flex-direction:column;
      gap:20px;
    }

    .founders-grid{
      display:grid;
      grid-template-columns:1fr 1fr;
      gap:20px;
    }

    .founder-card,
    .cta-panel{
      position:relative;
      overflow:hidden;
      isolation:isolate;
    }

    .founder-card{
      border-radius:24px;
      border:1px solid rgba(255,255,255,.09);
      background:
        linear-gradient(180deg, rgba(255,255,255,.009), rgba(255,255,255,.002)),
        rgba(0,0,0,.975);
      box-shadow:0 18px 50px rgba(0,0,0,.46);
      min-height:100%;
      transition:border-color .18s ease, transform .18s ease, box-shadow .18s ease;
    }

    .founder-card::before{
      content:"";
      position:absolute;
      inset:-24%;
      z-index:0;
      pointer-events:none;
      background-image:
        linear-gradient(rgba(var(--grid-rgb), .34) 1.35px, transparent 1.35px),
        linear-gradient(90deg, rgba(var(--grid-rgb), .34) 1.35px, transparent 1.35px);
      background-size:38px 38px;
      transform:rotate(13deg) scale(1.18);
      animation:gridDrift 16s linear infinite;
      opacity:.95;
      filter:
        drop-shadow(0 0 12px rgba(var(--grid-rgb), .18))
        drop-shadow(0 0 24px rgba(var(--grid-rgb), .09));
    }

    .founder-card::after{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 20% 18%, rgba(var(--grid-rgb), .14), transparent 26%),
        radial-gradient(circle at 80% 82%, rgba(var(--grid-rgb), .10), transparent 30%),
        linear-gradient(180deg, rgba(0,0,0,.34), rgba(0,0,0,.16));
      z-index:1;
      pointer-events:none;
    }

    @keyframes gridDrift{
      from{
        transform:translate3d(-66px, -44px, 0) rotate(13deg) scale(1.18);
      }
      to{
        transform:translate3d(66px, 44px, 0) rotate(13deg) scale(1.18);
      }
    }

    .founder-card:hover{
      transform:translateY(-4px);
      border-color:rgba(255,255,255,.22);
      box-shadow:0 24px 70px rgba(0,0,0,.58);
    }

    .cursor-glow{
      position:absolute;
      width:140px;
      height:140px;
      border-radius:50%;
      pointer-events:none;
      left:0;
      top:0;
      transform:translate(-50%, -50%);
      opacity:0;
      transition:opacity .18s ease;
      z-index:2;
      background:radial-gradient(
        circle,
        color-mix(in srgb, var(--active) 32%, transparent) 0%,
        color-mix(in srgb, var(--active) 16%, transparent) 34%,
        transparent 72%
      );
      filter:blur(9px);
    }

    .founder-inner{
      position:relative;
      z-index:3;
      padding:26px 24px 24px;
    }

    .founder-label{
      text-transform:uppercase;
      letter-spacing:.15em;
      font-size:.68rem;
      font-weight:900;
      color:var(--active);
      margin-bottom:8px;
      font-family:"Oswald", Arial, sans-serif;
    }

    .founder-name{
      font-family:"Oswald", Arial, sans-serif;
      font-size:2.05rem;
      line-height:1;
      font-weight:600;
      text-transform:uppercase;
      margin-bottom:10px;
    }

    .founder-sub{
      color:#ffffff;
      font-size:.96rem;
      line-height:1.75;
      margin-bottom:14px;
      overflow-wrap:anywhere;
    }

    .founder-copy{
      color:var(--muted);
      font-size:.93rem;
      line-height:1.68;
      overflow-wrap:anywhere;
    }

    .cta-panel{
      border-radius:22px;
      border:1px solid rgba(255,255,255,.085);
      background:
        linear-gradient(180deg, rgba(255,255,255,.006), rgba(255,255,255,.001)),
        rgba(0,0,0,.975);
      padding:20px;
    }

    .cta-panel::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(180deg, rgba(0,0,0,.18), rgba(0,0,0,.12));
      z-index:1;
      pointer-events:none;
    }

    .cta-row{
      position:relative;
      z-index:2;
      display:grid;
      grid-template-columns:repeat(3, minmax(0,1fr));
      gap:12px;
    }

    .cta-row a{
      display:flex;
      align-items:center;
      justify-content:center;
      min-height:58px;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.065);
      background:
        linear-gradient(180deg, rgba(255,255,255,.003), rgba(255,255,255,.001)),
        rgba(0,0,0,.96);
      color:#fff;
      font-family:"Oswald", Arial, sans-serif;
      font-size:.96rem;
      font-weight:600;
      letter-spacing:.08em;
      text-transform:uppercase;
      transition:border-color .18s ease, box-shadow .18s ease, transform .18s ease;
    }

    .cta-row a:hover{
      border-color:rgba(255,255,255,.22);
      box-shadow:var(--glow);
      transform:translateY(-2px);
    }

    .footer{
      position:relative;
      z-index:3;
      padding:0 22px 22px;
    }

    .footer-inner{
      border-top:1px solid rgba(255,255,255,.08);
      padding-top:18px;
      display:flex;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
      color:var(--muted-soft);
      font-size:.94rem;
    }

    @media (max-width: 1024px){
      .cursor-glow{
        display:none;
      }
    }

    @media (max-width: 900px){
      .page-wrap{
        padding:98px 24px 46px;
      }
    }

    @media (max-width: 768px){
      body{
        background:#000;
        background-color:#000;
      }

      .showcase{
        background:#000;
      }

      .topbar-inner{
        padding:14px 14px;
      }

      .nav a{
        padding:10px 14px;
        font-size:0.9rem;
      }

      .page-wrap{
        padding:92px 10px 34px;
      }

      .showcase{
        border-radius:22px;
      }

      .section-stack{
        padding:12px 12px 12px;
        gap:14px;
      }

      .founders-grid{
        grid-template-columns:1fr;
        gap:12px;
      }

      .founder-card{
        border-radius:18px;
      }

      .founder-card::before{
        background-size:34px 34px;
        animation:gridDrift 16s linear infinite;
        opacity:.98;
      }

      .founder-inner{
        padding:18px 16px 16px;
      }

      .founder-name{
        font-size:1.8rem;
      }

      .founder-sub{
        font-size:.97rem;
        line-height:1.62;
      }

      .founder-copy{
        font-size:.95rem;
        line-height:1.66;
      }

      .cta-panel{
        border-radius:18px;
        padding:12px;
      }

      .cta-row{
        grid-template-columns:1fr;
      }

      .cta-row a{
        min-height:52px;
        border-radius:14px;
        font-size:.9rem;
      }

      .footer{
        padding:0 12px 14px;
      }

      .footer-inner{
        font-size:.88rem;
      }
    }

    @media (max-width: 430px){
      .topbar-inner{
        padding:12px 10px;
      }

      .nav{
        gap:8px;
      }

      .nav a{
        padding:9px 12px;
        font-size:.84rem;
      }

      .page-wrap{
        padding:88px 8px 28px;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <nav class="nav">
        <a href="home.html">Home</a>
        <a href="services.html">Services</a>
        <a href="about.html" class="active">About</a>
      </nav>
    </div>
  </header>

  <main class="page-wrap">
    <section class="showcase">
      <div class="section-stack">
        <section class="founders-grid">
          <article class="founder-card glow-card">
            <div class="cursor-glow"></div>
            <div class="founder-inner">
              <div class="founder-label">Founder</div>
              <h2 class="founder-name">Russell</h2>
              <div class="founder-sub">
                Field experience, real-world knowledge, and a standard for doing things right.
              </div>
              <p class="founder-copy">
                Russell helped build this company around a simple idea: give customers the kind of service they actually want. That means honest communication, clean work, and dependable follow-through. Licensed pesticide applicator here in Arkansas.
              </p>
            </div>
          </article>

          <article class="founder-card glow-card">
            <div class="cursor-glow"></div>
            <div class="founder-inner">
              <div class="founder-label">Founder</div>
              <h2 class="founder-name">Zamir</h2>
              <div class="founder-sub">
                Backed the vision early and helped shape the company from the ground up.
              </div>
              <p class="founder-copy">
                Zamir helped shape the company around being easy to work with and easy to trust. That means clear communication, a more personal experience, and a company that feels different from the typical corporate approach people are used to.
              </p>
            </div>
          </article>
        </section>

        <section class="cta-panel">
          <div class="cta-row">
            <a href="tel:8709197114">Call</a>
            <a href="sms:8709197114">Text</a>
            <a href="mailto:gmail@allseasonpestllc.com">Email</a>
          </div>
        </section>
      </div>

      <footer class="footer">
        <div class="footer-inner">
          <span>© 2026 All Season Pest Control</span>
          <span>Jonesboro, Arkansas</span>
        </div>
      </footer>
    </section>
  </main>

  <script>
    const glowCards = document.querySelectorAll(".glow-card");

    if (window.innerWidth > 1024) {
      glowCards.forEach((card) => {
        const glow = card.querySelector(".cursor-glow");

        card.addEventListener("mousemove", (event) => {
          const rect = card.getBoundingClientRect();
          const x = event.clientX - rect.left;
          const y = event.clientY - rect.top;
          glow.style.left = `${x}px`;
          glow.style.top = `${y}px`;
          glow.style.opacity = "1";
        });

        card.addEventListener("mouseenter", () => {
          glow.style.opacity = "1";
        });

        card.addEventListener("mouseleave", () => {
          glow.style.opacity = "0";
        });
      });
    }
  </script>
</body>
</html>
