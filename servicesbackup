<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"
  />
  <title>Services | All Season Pest Control</title>
  <meta
    name="description"
    content="Pest control services from All Season Pest Control in Jonesboro, Arkansas."
  />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Sora:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root{
      --text:#ffffff;
      --muted:rgba(255,255,255,.82);
      --muted-soft:rgba(255,255,255,.54);
      --shadow:0 18px 60px rgba(0,0,0,.58);
      --gold:#ffd05c;
      --silver:#dddddd;
      --green:#58e08f;
      --red:#ff5c5c;
      --brown:#d09a65;
      --blue:#6ee7eb;
      --active:#ffd05c;
      --max:1200px;
      --glow:0 0 22px rgba(255,255,255,.12);
      --grid-rgb:255,208,92;
      --parallaxY:0px;
    }

    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
      min-width:0;
    }

    html{
      scroll-behavior:smooth;
      background:#000;
    }

    body{
      background:
        radial-gradient(circle at top, rgba(var(--grid-rgb), .065), transparent 28%),
        linear-gradient(180deg, #000000 0%, #000000 100%);
      background-color:#000;
      color:var(--text);
      font-family:"Sora", Inter, Arial, Helvetica, sans-serif;
      min-height:100vh;
      overflow-x:hidden;
      padding-bottom:max(24px, env(safe-area-inset-bottom));
    }

    a{
      color:inherit;
      text-decoration:none;
    }

    button,
    a,
    .service-btn{
      -webkit-tap-highlight-color: transparent;
      font: inherit;
    }

    .topbar{
      position:fixed;
      top:0;
      left:0;
      width:100%;
      z-index:1000;
      backdrop-filter:blur(14px);
      background:rgba(0, 0, 0, 0.86);
      border-bottom:1px solid rgba(255,255,255,.24);
    }

    .topbar-inner{
      max-width:var(--max);
      margin:0 auto;
      padding:14px 20px;
      display:flex;
      justify-content:center;
      align-items:center;
    }

    .nav{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      justify-content:center;
    }

    .nav a{
      padding:11px 18px;
      border:1px solid rgba(255,255,255,.34);
      border-radius:999px;
      background:rgba(255,255,255,.01);
      color:#fff;
      font-family:"Oswald", Arial, sans-serif;
      font-weight:600;
      font-size:0.98rem;
      letter-spacing:0.04em;
      text-transform:uppercase;
      transition:0.2s ease;
    }

    .nav a:hover,
    .nav a.active{
      border-color:rgba(255,255,255,.84);
      box-shadow:var(--glow);
      transform:translateY(-1px);
    }

    .page-wrap{
      max-width:1240px;
      margin:0 auto;
      padding:104px 20px 64px;
      overflow-x:hidden;
    }

    .showcase{
      position:relative;
      width:100%;
      border-radius:28px;
      border:1px solid rgba(255,255,255,.08);
      background:
        linear-gradient(180deg, rgba(255,255,255,.004), rgba(255,255,255,.001)),
        rgba(0,0,0,.995);
      box-shadow:var(--shadow);
      overflow:hidden;
      isolation:isolate;
    }

    .showcase::before{
      content:"";
      position:absolute;
      inset:0;
      background:
        radial-gradient(circle at 18% 14%, rgba(var(--grid-rgb), .055), transparent 22%),
        radial-gradient(circle at 82% 20%, rgba(var(--grid-rgb), .03), transparent 24%),
        radial-gradient(circle at 50% 100%, rgba(var(--grid-rgb), .055), transparent 34%);
      pointer-events:none;
      z-index:1;
    }

    .grid-bg{
      position:absolute;
      inset:-14%;
      z-index:0;
      pointer-events:none;
      transform:translate3d(0, var(--parallaxY), 0) scale(1.08);
      will-change:transform;
    }

    .grid-bg::before,
    .grid-bg::after{
      content:"";
      position:absolute;
      inset:0;
    }

    .grid-bg::before{
      background-image:
        linear-gradient(rgba(var(--grid-rgb), .34) 1.35px, transparent 1.35px),
        linear-gradient(90deg, rgba(var(--grid-rgb), .34) 1.35px, transparent 1.35px);
      background-size:40px 40px;
      transform:translate3d(0, 0, 0) rotate(-8deg) scale(1.12);
      opacity:.9;
      animation:gridDrift 20s linear infinite;
      filter:
        drop-shadow(0 0 12px rgba(var(--grid-rgb), .18))
        drop-shadow(0 0 24px rgba(var(--grid-rgb), .09));
    }

    .grid-bg::after{
      background:
        radial-gradient(circle at 18% 18%, rgba(var(--grid-rgb), .12), transparent 24%),
        radial-gradient(circle at 78% 24%, rgba(var(--grid-rgb), .08), transparent 28%),
        radial-gradient(circle at 50% 85%, rgba(var(--grid-rgb), .10), transparent 34%);
      opacity:.85;
      filter:blur(22px);
      transform:scale(1.08);
    }

    @keyframes gridDrift {
      from {
        transform: translate3d(-66px, -44px, 0) rotate(-8deg) scale(1.12);
      }
      to {
        transform: translate3d(66px, 44px, 0) rotate(-8deg) scale(1.12);
      }
    }

    .grid-vignette-left,
    .grid-vignette-right{
      position:absolute;
      top:0;
      bottom:0;
      width:120px;
      z-index:1;
      pointer-events:none;
    }

    .grid-vignette-left{
      left:0;
      background:linear-gradient(90deg, rgba(0,0,0,.985), rgba(0,0,0,0));
    }

    .grid-vignette-right{
      right:0;
      background:linear-gradient(270deg, rgba(0,0,0,.985), rgba(0,0,0,0));
    }

    .panel-wrap{
      position:relative;
      z-index:3;
      padding:18px 18px 8px;
    }

    .focus-card{
      width:100%;
      max-width:840px;
      margin:0 auto;
      border-radius:28px;
      border:1px solid rgba(255,255,255,.1);
      background:
        linear-gradient(180deg, rgba(255,255,255,.008), rgba(255,255,255,.002)),
        rgba(0,0,0,.975);
      backdrop-filter:blur(4px);
      box-shadow:0 18px 60px rgba(0,0,0,.62);
      overflow:hidden;
      transition:border-color .18s ease, box-shadow .18s ease, background .18s ease;
      position:relative;
    }

    .focus-card::before{
      content:"";
      position:absolute;
      inset:0;
      z-index:0;
      pointer-events:none;
      background:
        radial-gradient(circle at 18% 16%, rgba(var(--grid-rgb), .08), transparent 20%),
        radial-gradient(circle at 82% 84%, rgba(var(--grid-rgb), .06), transparent 28%);
      opacity:.9;
    }

    .cursor-glow{
      position:absolute;
      width:130px;
      height:130px;
      border-radius:50%;
      pointer-events:none;
      left:0;
      top:0;
      transform:translate(-50%, -50%);
      opacity:0;
      transition:opacity .18s ease;
      z-index:1;
      background:radial-gradient(
        circle,
        color-mix(in srgb, var(--active) 34%, transparent) 0%,
        color-mix(in srgb, var(--active) 17%, transparent) 34%,
        transparent 72%
      );
      filter:blur(8px);
    }

    .mobile-card-grid{
      display:none;
    }

    .focus-top,
    .focus-content{
      position:relative;
      z-index:2;
    }

    .focus-top{
      padding:24px 24px 16px;
      border-bottom:1px solid rgba(255,255,255,.06);
      overflow:hidden;
      background:linear-gradient(180deg, rgba(255,255,255,.004), rgba(255,255,255,0));
    }

    .focus-head{
      position:relative;
      z-index:2;
      display:flex;
      align-items:flex-start;
      gap:16px;
      width:100%;
    }

    .focus-copy{
      flex:1 1 auto;
      min-width:0;
    }

    .focus-badge{
      width:56px;
      height:56px;
      border-radius:18px;
      display:flex;
      align-items:center;
      justify-content:center;
      flex:none;
      border:1px solid color-mix(in srgb, var(--active) 30%, rgba(255,255,255,.09));
      background:color-mix(in srgb, var(--active) 6%, rgba(255,255,255,.01));
      color:var(--active);
      box-shadow:0 0 24px color-mix(in srgb, var(--active) 10%, transparent);
    }

    .focus-badge svg{
      width:28px;
      height:28px;
      stroke:currentColor;
      fill:none;
      stroke-width:1.9;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    .focus-kicker{
      text-transform:uppercase;
      letter-spacing:.18em;
      font-size:.72rem;
      font-weight:900;
      color:var(--active);
      margin-bottom:8px;
      font-family:"Oswald", Arial, sans-serif;
      text-shadow:0 0 14px color-mix(in srgb, var(--active) 16%, transparent);
    }

    .focus-title{
      font-family:"Oswald", Arial, sans-serif;
      font-size:clamp(1.65rem, 3vw, 2.85rem);
      font-weight:600;
      line-height:1;
      letter-spacing:-.02em;
      margin-bottom:12px;
      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
      text-transform:uppercase;
    }

    .focus-desc{
      color:var(--muted);
      font-size:.98rem;
      line-height:1.7;
      max-width:60ch;
      overflow-wrap:anywhere;
    }

    .focus-content{
      padding:16px 24px 22px;
      width:100%;
    }

    .focus-sub{
      color:rgba(255,255,255,.94);
      font-size:.96rem;
      line-height:1.75;
      margin-bottom:14px;
      overflow-wrap:anywhere;
    }

    .info-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:12px;
      width:100%;
    }

    .info-box{
      border:1px solid color-mix(in srgb, var(--active) 16%, rgba(255,255,255,.065));
      border-radius:18px;
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--active) 3%, rgba(255,255,255,.003)), rgba(255,255,255,.001)),
        rgba(0,0,0,.96);
      padding:14px 14px 13px;
      position:relative;
      z-index:2;
      box-shadow:inset 0 0 0 1px rgba(255,255,255,.015);
    }

    .info-box .label{
      text-transform:uppercase;
      letter-spacing:.15em;
      font-size:.68rem;
      font-weight:900;
      color:var(--active);
      margin-bottom:8px;
      font-family:"Oswald", Arial, sans-serif;
      text-shadow:0 0 12px color-mix(in srgb, var(--active) 16%, transparent);
    }

    .info-box p{
      color:#f3f3f3;
      line-height:1.68;
      font-size:.93rem;
      overflow-wrap:anywhere;
    }

    .service-selector-bottom{
      position:relative;
      z-index:3;
      padding:12px 16px 16px;
      border-top:1px solid rgba(255,255,255,.055);
      background:linear-gradient(180deg, rgba(0,0,0,.14), rgba(0,0,0,.34));
      backdrop-filter:blur(2px);
    }

    .service-rail{
      display:flex;
      gap:14px;
      overflow-x:auto;
      overflow-y:hidden;
      padding:12px 26px 14px;
      margin:0 -8px;
      scrollbar-width:none;
      -webkit-overflow-scrolling:touch;
      overscroll-behavior-x:contain;
      justify-content:flex-start;
      align-items:center;
      scroll-snap-type:x mandatory;
      scroll-padding-inline:26px;
      scroll-behavior:auto;
      touch-action:pan-x;
    }

    .service-rail::-webkit-scrollbar{
      display:none;
    }

    .service-btn{
      flex:0 0 212px;
      border:1px solid rgba(255,255,255,.07);
      background:
        linear-gradient(180deg, rgba(255,255,255,.004), rgba(255,255,255,.001)),
        rgba(0,0,0,.955);
      color:#fff;
      border-radius:20px;
      padding:15px 15px 14px;
      text-align:left;
      cursor:pointer;
      transition:
        border-color .18s ease,
        box-shadow .18s ease,
        background .18s ease,
        transform .22s ease,
        opacity .22s ease;
      transform:scale(.92);
      opacity:.68;
      scroll-snap-align:center;
    }

    .service-btn.near-active{
      transform:scale(.96);
      opacity:.88;
    }

    .service-btn.active{
      border-color:color-mix(in srgb, var(--active) 52%, rgba(255,255,255,.05));
      background:
        linear-gradient(180deg, color-mix(in srgb, var(--active) 8%, rgba(255,255,255,.003)), rgba(255,255,255,.001)),
        rgba(2,2,2,.975);
      box-shadow:
        0 0 0 1px color-mix(in srgb, var(--active) 12%, transparent) inset,
        0 0 24px color-mix(in srgb, var(--active) 10%, transparent);
      transform:scale(1);
      opacity:1;
    }

    .service-btn-top{
      display:flex;
      align-items:center;
      gap:10px;
      margin-bottom:6px;
    }

    .service-icon{
      width:36px;
      height:36px;
      border-radius:12px;
      display:flex;
      align-items:center;
      justify-content:center;
      border:1px solid color-mix(in srgb, var(--active) 18%, rgba(255,255,255,.07));
      background:color-mix(in srgb, var(--active) 5%, rgba(255,255,255,.01));
      color:var(--active);
      flex:none;
      transition:width .22s ease, height .22s ease, border-radius .22s ease;
      box-shadow:0 0 18px color-mix(in srgb, var(--active) 8%, transparent);
    }

    .service-icon svg{
      width:18px;
      height:18px;
      stroke:currentColor;
      fill:none;
      stroke-width:1.9;
      stroke-linecap:round;
      stroke-linejoin:round;
    }

    .service-btn .kicker{
      display:block;
      font-size:.62rem;
      letter-spacing:.15em;
      text-transform:uppercase;
      color:color-mix(in srgb, var(--active) 62%, rgba(255,255,255,.56));
      font-weight:800;
      margin-bottom:4px;
      transition:font-size .22s ease;
      font-family:"Oswald", Arial, sans-serif;
    }

    .service-btn.active .kicker{
      font-size:.68rem;
    }

    .service-btn .name{
      display:block;
      font-family:"Oswald", Arial, sans-serif;
      font-size:.94rem;
      font-weight:600;
      letter-spacing:.01em;
      line-height:1.1;
      word-break:break-word;
      transition:font-size .22s ease;
      min-height:2.25em;
      text-transform:uppercase;
    }

    .service-btn.active .name{
      font-size:1.08rem;
    }

    .footer{
      position:relative;
      z-index:3;
      padding:0 22px 22px;
    }

    .footer-inner{
      border-top:1px solid rgba(255,255,255,.08);
      padding-top:18px;
      display:flex;
      justify-content:space-between;
      gap:12px;
      flex-wrap:wrap;
      color:var(--muted-soft);
      font-size:.94rem;
    }

    @media (max-width: 1024px){
      .cursor-glow{
        display:none;
      }

      .grid-bg{
        inset:-10%;
        transform:translate3d(0, 0, 0) scale(1.06);
      }

      .grid-bg::before{
        opacity:.72;
      }

      .focus-card{
        max-width:820px;
      }
    }

    @media (max-width: 900px){
      .page-wrap{
        padding:98px 24px 46px;
      }

      .focus-title{
        font-size:clamp(1.45rem, 2.9vw, 2.3rem);
      }
    }

    @media (max-width: 768px){
      body{
        background:#000;
        background-color:#000;
      }

      .showcase{
        background:#000;
      }

      .showcase::before{
        display:none;
      }

      .grid-bg{
        display:none;
      }

      .grid-vignette-left,
      .grid-vignette-right{
        display:none;
      }

      .topbar-inner{
        padding:14px 14px;
      }

      .nav a{
        padding:10px 14px;
        font-size:0.9rem;
      }

      .page-wrap{
        padding:92px 10px 34px;
      }

      .showcase{
        border-radius:22px;
      }

      .panel-wrap{
        padding:12px 12px 4px;
      }

      .focus-card{
        border-radius:20px;
        background:
          linear-gradient(180deg, rgba(255,255,255,.01), rgba(255,255,255,.002)),
          rgba(0,0,0,.985);
      }

      .mobile-card-grid{
        display:block;
        position:absolute;
        inset:0;
        z-index:0;
        pointer-events:none;
        overflow:hidden;
      }

      .mobile-card-grid::before,
      .mobile-card-grid::after{
        content:"";
        position:absolute;
        inset:-14%;
      }

      .mobile-card-grid::before{
        background-image:
          linear-gradient(rgba(var(--grid-rgb), .34) 1.3px, transparent 1.3px),
          linear-gradient(90deg, rgba(var(--grid-rgb), .34) 1.3px, transparent 1.3px);
        background-size:38px 38px;
        transform:rotate(-8deg) scale(1.1);
        opacity:.9;
        animation:gridDrift 20s linear infinite;
        filter:
          drop-shadow(0 0 10px rgba(var(--grid-rgb), .16))
          drop-shadow(0 0 20px rgba(var(--grid-rgb), .07));
      }

      .mobile-card-grid::after{
        background:
          radial-gradient(circle at 22% 16%, rgba(var(--grid-rgb), .14), transparent 28%),
          radial-gradient(circle at 78% 84%, rgba(var(--grid-rgb), .1), transparent 34%),
          linear-gradient(180deg, rgba(0,0,0,.14), rgba(0,0,0,.22));
        opacity:.95;
        filter:blur(12px);
      }

      .focus-top{
        padding:16px 16px 12px;
        background:linear-gradient(180deg, rgba(0,0,0,.30), rgba(0,0,0,.12));
      }

      .focus-content{
        background:linear-gradient(180deg, rgba(0,0,0,.12), rgba(0,0,0,.18));
      }

      .focus-head{
        gap:12px;
      }

      .focus-badge{
        width:44px;
        height:44px;
        border-radius:14px;
        background:color-mix(in srgb, var(--active) 8%, rgba(0,0,0,.48));
      }

      .focus-badge svg{
        width:22px;
        height:22px;
      }

      .focus-kicker{
        font-size:.74rem;
        margin-bottom:8px;
      }

      .focus-title{
        font-size:1.55rem;
        margin-bottom:10px;
      }

      .focus-desc{
        font-size:.98rem;
        line-height:1.64;
      }

      .focus-content{
        padding:12px 16px 14px;
      }

      .focus-sub{
        font-size:.98rem;
        line-height:1.66;
        margin-bottom:12px;
      }

      .info-grid{
        grid-template-columns:1fr;
        gap:10px;
      }

      .info-box{
        border-radius:14px;
        padding:12px 13px 11px;
        background:
          linear-gradient(180deg, color-mix(in srgb, var(--active) 4%, rgba(0,0,0,.26)), rgba(0,0,0,.16)),
          rgba(0,0,0,.76);
      }

      .info-box .label{
        font-size:.74rem;
        margin-bottom:7px;
      }

      .info-box p{
        font-size:.95rem;
        line-height:1.6;
      }

      .service-selector-bottom{
        padding:10px 10px 12px;
      }

      .service-rail{
        gap:8px;
        padding:10px 16px 10px;
        scroll-padding-inline:16px;
      }

      .service-btn{
        flex:0 0 148px;
        border-radius:14px;
        padding:10px;
        transform:scale(.88);
        opacity:.62;
      }

      .service-btn.near-active{
        transform:scale(.95);
        opacity:.84;
      }

      .service-btn.active{
        padding:10px;
        transform:scale(1);
        opacity:1;
      }

      .service-icon{
        width:30px;
        height:30px;
        border-radius:10px;
      }

      .service-icon svg{
        width:15px;
        height:15px;
      }

      .service-btn .kicker{
        font-size:.54rem;
      }

      .service-btn.active .kicker{
        font-size:.60rem;
      }

      .service-btn .name{
        font-size:.78rem;
        min-height:2.28em;
      }

      .service-btn.active .name{
        font-size:.92rem;
      }

      .footer{
        padding:0 12px 14px;
      }

      .footer-inner{
        font-size:.88rem;
      }
    }

    @media (max-width: 430px){
      .topbar-inner{
        padding:12px 10px;
      }

      .nav{
        gap:8px;
      }

      .nav a{
        padding:9px 12px;
        font-size:.84rem;
      }

      .page-wrap{
        padding:88px 8px 28px;
      }

      .focus-title{
        font-size:1.42rem;
      }

      .focus-desc{
        font-size:.94rem;
      }

      .focus-sub{
        font-size:.94rem;
      }

      .info-box .label{
        font-size:.7rem;
      }

      .info-box p{
        font-size:.92rem;
      }
    }
  </style>
</head>
<body>
  <header class="topbar">
    <div class="topbar-inner">
      <nav class="nav">
        <a href="home.html">Home</a>
        <a href="services.html" class="active">Services</a>
        <a href="about.html">About</a>
      </nav>
    </div>
  </header>

  <main class="page-wrap">
    <section class="showcase">
      <div class="grid-bg" id="gridBg" aria-hidden="true"></div>
      <div class="grid-vignette-left" aria-hidden="true"></div>
      <div class="grid-vignette-right" aria-hidden="true"></div>

      <div class="panel-wrap">
        <div class="focus-card" id="focusCard">
          <div class="mobile-card-grid" aria-hidden="true"></div>
          <div class="cursor-glow" id="cursorGlow"></div>

          <div class="focus-top">
            <div class="focus-head">
              <div class="focus-badge" id="focusBadge"></div>
              <div class="focus-copy">
                <div class="focus-kicker" id="focusKicker"></div>
                <h2 class="focus-title" id="focusTitle"></h2>
                <p class="focus-desc" id="focusDesc"></p>
              </div>
            </div>
          </div>

          <div class="focus-content">
            <p class="focus-sub" id="focusSub"></p>

            <div class="info-grid">
              <div class="info-box">
                <div class="label" id="box1Label"></div>
                <p id="box1Text"></p>
              </div>
              <div class="info-box">
                <div class="label" id="box2Label"></div>
                <p id="box2Text"></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="service-selector-bottom">
        <div class="service-rail" id="serviceRail"></div>
      </div>

      <footer class="footer">
        <div class="footer-inner">
          <span>© 2026 All Season Pest Control</span>
          <span>Jonesboro, Arkansas</span>
        </div>
      </footer>
    </section>
  </main>

  <script>
    const iconMap = {
      bug: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 8.5c2.2 0 4 1.8 4 4.1V16c0 2.2-1.8 4-4 4s-4-1.8-4-4v-3.4c0-2.3 1.8-4.1 4-4.1Z"/><path d="M10.5 5.5 12 4l1.5 1.5"/><path d="M8 10 5.5 8.5M16 10l2.5-1.5M8 14H5M19 14h-3M8.5 18l-2 1.5M15.5 18l2 1.5"/></svg>`,
      shield: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v5c0 4.8-2.8 8.4-7 10-4.2-1.6-7-5.2-7-10V6l7-3Z"/><path d="M9.5 12.5 11 14l3.5-4"/></svg>`,
      paw: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 11.5c-1.2 0-2-1.3-2-2.8S6.8 6 8 6s2 1.3 2 2.7-.8 2.8-2 2.8ZM16 11.5c-1.2 0-2-1.3-2-2.8S14.8 6 16 6s2 1.3 2 2.7-.8 2.8-2 2.8ZM5.5 15.5c-1 0-1.7-1.1-1.7-2.4s.7-2.4 1.7-2.4 1.7 1.1 1.7 2.4-.7 2.4-1.7 2.4ZM18.5 15.5c-1 0-1.7-1.1-1.7-2.4s.7-2.4 1.7-2.4 1.7 1.1 1.7 2.4-.7 2.4-1.7 2.4Z"/><path d="M12 19.5c2.3 0 4.5-1.1 4.5-3.2 0-1.8-1.4-3.1-3.1-3.1-.7 0-1.1.2-1.4.5-.3-.3-.7-.5-1.4-.5-1.7 0-3.1 1.3-3.1 3.1 0 2.1 2.2 3.2 4.5 3.2Z"/></svg>`,
      mosquito: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 12v7"/><path d="M12 12 7 7M12 12l5-5M12 12l6 2M12 12 6 14"/><path d="M12 7.5c1.2 0 2-.8 2-1.8S13.2 4 12 4s-2 .8-2 1.7.8 1.8 2 1.8Z"/><path d="M10.5 19.5h3"/></svg>`,
      target: `<svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="7"/><circle cx="12" cy="12" r="3"/><path d="M12 5V3M19 12h2M12 21v-2M3 12h2"/></svg>`,
      leaf: `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M19 4c-7.5.4-12 4.8-12 10.5 0 3 2.2 5.5 5.4 5.5C18.3 20 20 13.9 19 4Z"/><path d="M8 16c2.5-2.4 4.8-4 8-5.5"/></svg>`
    };

    const baseServices = [
      {
        id: "general", color: "#ffd05c", rgb: "255,208,92", icon: "bug",
        kicker: "Core Service", title: "General Pests", buttonTitle: "General Pests",
        desc: "Built for common pest pressure around the home and designed to help keep activity down through consistent, dependable treatment.",
        sub: "This service typically targets pests such as ants, spiders, crickets, earwigs, silverfish, centipedes, millipedes, and other common invading insects. It does not cover bed bugs or termites.",
        box1Label: "Typical Coverage", box1Text: "Exterior foundation and eave treatment with full front to back curb spot treatment as needed.",
        box2Label: "Important Note", box2Text: "Interior/garage sprays are optional, not mandatory."
      },
      {
        id: "rodent", color: "#dddddd", rgb: "221,221,221", icon: "shield",
        kicker: "Monitoring + Control", title: "Rodent Control", buttonTitle: "Rodent Control",
        desc: "Focused on reducing and monitoring rodent activity through strategic bait placement and ongoing follow-up where needed.",
        sub: "Service includes inspection of active areas, exterior bait stations, sticky traps, and recommendations to help reduce conditions that contribute to rodent pressure around the home.",
        box1Label: "Service Focus", box1Text: "Ongoing monitoring, activity reduction, baiting, and follow-up based on the level of rodent pressure.",
        box2Label: "Important Note", box2Text: "Does not include moles, snakes, skunks, or squirrels."
      },
      {
        id: "tickflea", color: "#58e08f", rgb: "88,224,143", icon: "paw",
        kicker: "Granular Service", title: "Tick & Flea Treatment", buttonTitle: "Tick & Flea Treatment",
        desc: "Designed for properties dealing with biting pests in the yard, around pet areas, or in outdoor spaces where activity builds up.",
        sub: "These treatments focus on helping reduce active populations and improving control in the areas where ticks and fleas are most likely to be found. This is a granular product used in the yard.",
        box1Label: "Best For", box1Text: "Homes with pets, shaded yards, wildlife traffic, or recurring tick and flea activity outside.",
        box2Label: "Important Note", box2Text: "This is an optional add-on service for general pests."
      },
      {
        id: "mosquito", color: "#ff5c5c", rgb: "255,92,92", icon: "mosquito",
        kicker: "Seasonal Treatment", title: "Mosquito Treatment", buttonTitle: "Mosquito Treatment",
        desc: "Designed to help reduce mosquito pressure in the yard so you can enjoy outdoor areas more comfortably during the warmer months.",
        sub: "Treatment is typically focused on shaded foliage, harborage areas, and other outdoor zones where mosquitoes like to rest and build up. This is a recurring service from April-September.",
        box1Label: "Best For", box1Text: "Homes with patios, backyards, pets, or heavy mosquito pressure during the season.",
        box2Label: "Service Approach", box2Text: "Treating nesting and breeding points in the yard."
      },
      {
        id: "roach", color: "#d09a65", rgb: "208,154,101", icon: "target",
        kicker: "Specialized Treatment", title: "German Roaches", buttonTitle: "German Roaches",
        desc: "Built for active infestations that need more aggressive and targeted attention than standard routine pest service.",
        sub: "Treatment may include detailed inspection, targeted crack-and-crevice applications, baiting, and follow-up service depending on the level of activity and conditions inside the home.",
        box1Label: "Best For", box1Text: "Active German cockroach infestations with monthly treatment to fully eliminate the problem.",
        box2Label: "Important Note", box2Text: "Results depend heavily on severity and sanitation."
      },
      {
        id: "weed", color: "#6ee7eb", rgb: "110,231,235", icon: "leaf",
        kicker: "Specialized Treatment", title: "Weed Control", buttonTitle: "Weed Control",
        desc: "Designed to help reduce unwanted weed growth, keep rock and gravel areas cleaner, and improve the overall appearance of the property.",
        sub: "Treatment plans are based on the season, weed pressure, and the overall condition of the area being treated to ensure effective results. Treatments are done in the early spring and again in late summer.",
        box1Label: "Best For", box1Text: "Properties dealing with visible weed pressure in the rocks, gravel, sand, along edges, and other non-lawn areas.",
        box2Label: "Service Approach", box2Text: "Price varies by total square feet of treatment."
      }
    ];

    const serviceRail = document.getElementById("serviceRail");
    const focusCard = document.getElementById("focusCard");
    const cursorGlow = document.getElementById("cursorGlow");
    const focusBadge = document.getElementById("focusBadge");
    const focusKicker = document.getElementById("focusKicker");
    const focusTitle = document.getElementById("focusTitle");
    const focusDesc = document.getElementById("focusDesc");
    const focusSub = document.getElementById("focusSub");
    const box1Label = document.getElementById("box1Label");
    const box1Text = document.getElementById("box1Text");
    const box2Label = document.getElementById("box2Label");
    const box2Text = document.getElementById("box2Text");
    const rootStyle = document.documentElement.style;
    const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;
    const cloneRepeat = 2;
    let currentActiveId = "general";
    let touchStartX = 0;
    let touchStartY = 0;
    let touchLocked = false;
    let isAnimatingSwipe = false;
    let suppressTapAfterSwipe = false;
    let tickingParallax = false;

    function triggerHaptic(pattern = 12) {
      try {
        if (isTouchDevice && "vibrate" in navigator) navigator.vibrate(pattern);
      } catch (_) {}
    }

    function getRailServices() {
      const before = [];
      const after = [];
      for (let i = 0; i < cloneRepeat; i++) {
        before.push(...baseServices);
        after.push(...baseServices);
      }
      return [...before, ...baseServices, ...after];
    }

    function renderButtons() {
      serviceRail.innerHTML = "";
      const railServices = getRailServices();
      railServices.forEach((service, index) => {
        const button = document.createElement("button");
        button.className = "service-btn";
        button.dataset.id = service.id;
        button.dataset.index = index;
        button.style.setProperty("--active", service.color);
        button.innerHTML = `
          <div class="service-btn-top">
            <div class="service-icon">${iconMap[service.icon]}</div>
            <div>
              <span class="kicker">${service.kicker}</span>
              <span class="name">${service.buttonTitle || service.title}</span>
            </div>
          </div>
        `;
        button.addEventListener("click", () => {
          if (suppressTapAfterSwipe || isAnimatingSwipe) return;
          triggerHaptic(12);
          goToServiceById(service.id);
        });
        serviceRail.appendChild(button);
      });
    }

    function getButtonsById(id) {
      return [...document.querySelectorAll(`.service-btn[data-id="${id}"]`)];
    }

    function getMiddleSetButton(id) {
      const buttons = getButtonsById(id);
      const segmentLength = baseServices.length;
      const middleIndexStart = segmentLength * cloneRepeat;
      return buttons.find(btn => {
        const idx = Number(btn.dataset.index);
        return idx >= middleIndexStart && idx < middleIndexStart + segmentLength;
      }) || buttons[0] || null;
    }

    function centerButton(button, smooth = true) {
      if (!button) return;
      const targetLeft = button.offsetLeft - (serviceRail.clientWidth / 2) + (button.clientWidth / 2);
      serviceRail.scrollTo({ left: targetLeft, behavior: smooth ? "smooth" : "auto" });
    }

    function updateRailClasses(activeButton) {
      const allButtons = [...document.querySelectorAll(".service-btn")];
      allButtons.forEach(btn => btn.classList.remove("near-active"));
      if (!activeButton) return;
      const rect = activeButton.getBoundingClientRect();
      const activeCenter = rect.left + rect.width / 2;
      allButtons.forEach(btn => {
        if (btn === activeButton) return;
        const r = btn.getBoundingClientRect();
        const center = r.left + r.width / 2;
        if (Math.abs(center - activeCenter) < 340) btn.classList.add("near-active");
      });
    }

    function normalizeRailPosition() {
      const targetButton = getMiddleSetButton(currentActiveId);
      if (!targetButton) return;
      centerButton(targetButton, false);
      updateRailClasses(targetButton);
    }

    function setThemeColor(service) {
      rootStyle.setProperty("--active", service.color);
      rootStyle.setProperty("--grid-rgb", service.rgb);
    }

    function updateServiceContent(service) {
      currentActiveId = service.id;
      setThemeColor(service);
      document.querySelectorAll(".service-btn").forEach(btn => {
        btn.classList.toggle("active", btn.dataset.id === service.id);
      });
      focusBadge.innerHTML = iconMap[service.icon];
      focusBadge.style.color = service.color;
      focusKicker.textContent = service.kicker;
      focusTitle.textContent = service.title;
      focusTitle.title = service.title;
      focusDesc.textContent = service.desc;
      focusSub.textContent = service.sub;
      box1Label.textContent = service.box1Label;
      box1Text.textContent = service.box1Text;
      box2Label.textContent = service.box2Label;
      box2Text.textContent = service.box2Text;
      focusKicker.style.color = service.color;
      document.querySelectorAll(".label").forEach(label => label.style.color = service.color);
      focusCard.style.borderColor = `${service.color}30`;
      focusCard.style.boxShadow = `0 18px 60px rgba(0,0,0,.62), 0 0 26px ${service.color}10`;
    }

    function getServiceIndexById(id) {
      return baseServices.findIndex(s => s.id === id);
    }

    function goToServiceIndex(index) {
      const total = baseServices.length;
      const wrappedIndex = (index + total) % total;
      const nextService = baseServices[wrappedIndex];
      const middleButton = getMiddleSetButton(nextService.id);
      if (!middleButton) return;
      isAnimatingSwipe = true;
      updateServiceContent(nextService);
      centerButton(middleButton, true);
      updateRailClasses(middleButton);
      setTimeout(() => {
        const snapButton = getMiddleSetButton(nextService.id);
        centerButton(snapButton, false);
        updateRailClasses(snapButton);
        isAnimatingSwipe = false;
      }, 260);
    }

    function goToServiceById(id) {
      const index = getServiceIndexById(id);
      if (index === -1) return;
      goToServiceIndex(index);
    }

    function stepService(direction) {
      if (isAnimatingSwipe) return;
      const currentIndex = getServiceIndexById(currentActiveId);
      if (currentIndex === -1) return;
      triggerHaptic(10);
      goToServiceIndex(currentIndex + direction);
    }

    function updateParallax() {
      tickingParallax = false;
      if (window.innerWidth <= 1024) {
        rootStyle.setProperty("--parallaxY", "0px");
        return;
      }
      const y = Math.min(window.scrollY * 0.12, 42);
      rootStyle.setProperty("--parallaxY", `${y}px`);
    }

    function requestParallax() {
      if (tickingParallax) return;
      tickingParallax = true;
      requestAnimationFrame(updateParallax);
    }

    renderButtons();
    updateServiceContent(baseServices[0]);

    requestAnimationFrame(() => {
      normalizeRailPosition();
      updateParallax();
    });

    serviceRail.addEventListener("touchstart", (event) => {
      if (window.innerWidth > 768) return;
      touchStartX = event.touches[0].clientX;
      touchStartY = event.touches[0].clientY;
      touchLocked = false;
      suppressTapAfterSwipe = false;
    }, { passive: true });

    serviceRail.addEventListener("touchmove", (event) => {
      if (window.innerWidth > 768 || isAnimatingSwipe) return;
      const deltaX = event.touches[0].clientX - touchStartX;
      const deltaY = event.touches[0].clientY - touchStartY;
      if (touchLocked) {
        event.preventDefault();
        return;
      }
      if (Math.abs(deltaX) > 22 && Math.abs(deltaX) > Math.abs(deltaY)) {
        touchLocked = true;
        suppressTapAfterSwipe = true;
        event.preventDefault();
      }
    }, { passive: false });

    serviceRail.addEventListener("touchend", (event) => {
      if (window.innerWidth > 768 || isAnimatingSwipe) return;
      const changedTouch = event.changedTouches[0];
      if (!changedTouch) return;
      const deltaX = changedTouch.clientX - touchStartX;
      const deltaY = changedTouch.clientY - touchStartY;
      if (Math.abs(deltaX) > 38 && Math.abs(deltaX) > Math.abs(deltaY)) {
        stepService(deltaX < 0 ? 1 : -1);
        setTimeout(() => suppressTapAfterSwipe = false, 250);
      } else {
        const middleButton = getMiddleSetButton(currentActiveId);
        centerButton(middleButton, true);
        updateRailClasses(middleButton);
        suppressTapAfterSwipe = false;
      }
      touchLocked = false;
    }, { passive: true });

    serviceRail.addEventListener("scroll", () => {
      if (window.innerWidth > 768 || isAnimatingSwipe) return;
      const middleButton = getMiddleSetButton(currentActiveId);
      updateRailClasses(middleButton);
    }, { passive: true });

    window.addEventListener("resize", () => {
      updateServiceContent(baseServices[getServiceIndexById(currentActiveId)] || baseServices[0]);
      normalizeRailPosition();
      isAnimatingSwipe = false;
      suppressTapAfterSwipe = false;
      updateParallax();
    });

    window.addEventListener("scroll", requestParallax, { passive: true });

    if (window.innerWidth > 1024) {
      focusCard.addEventListener("mousemove", (event) => {
        const rect = focusCard.getBoundingClientRect();
        const x = event.clientX - rect.left;
        const y = event.clientY - rect.top;
        cursorGlow.style.left = `${x}px`;
        cursorGlow.style.top = `${y}px`;
        cursorGlow.style.opacity = "1";
      });

      focusCard.addEventListener("mouseenter", () => {
        cursorGlow.style.opacity = "1";
      });

      focusCard.addEventListener("mouseleave", () => {
        cursorGlow.style.opacity = "0";
      });
    }
  </script>
</body>
</html>